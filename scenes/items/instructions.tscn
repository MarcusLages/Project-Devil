theme_override_font_sizes/font_size = 12
text = "1. Press the red button to receive customers' bargain requests and their profiles;
2. Assess their profiles and our Patron codices to assign them to the Patron that better suits their needs;
3. ████ Prime is no more;
4. Assign a Patron by stamping their profile with a Patron's corresponding stamp;
5. After stamping, press the red button to receive your next assignment;
6. ████ Prime is no more;
7. Process each request in a timely manner to prevent bottlenecks;
8. Appease our Patrons above all other concerns. They are our real clients;
9. ████ Prime is no more.
"
autowrap_mode = 2

