theme_override_font_sizes/normal_font_size = 14
text = "Log #8
THIS MAKES NO SENSE! EVERYTHING MUST MAKE SENSE! EVERYTHING IS BECAUSE OF PREDETERMINED REASONS DEFINED IN THE STRUCTURE OF THE UNIVERSE’S CODE!
I REFUSE TO BELIEVE OTHERWISE.
"

