theme_override_font_sizes/normal_font_size = 14
text = "Log #2
Good progress so far. The papers speak of ‘dreamers’ and ‘illusions’, but what I witness before me is truer than truth itself. Reality is imperfect; Eden is not.
"

[node name="RichTextLabel2" parent="ZoomedContent/3" index="2"]
