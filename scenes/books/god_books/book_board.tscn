text = "8443. Client Rights


8444. Prohibited Activities

8444.1 Any activities disruptive to the Global State of Balance, as defined by the Cimmerian Council of Guardians, are strictly prohibited from being performed, both in the undertaking of their sacrificial offers, as in the content of their objects of desire."

[node name="RichTextLabel2" parent="ZoomedContent/4" index="2"]
offset_left = 8.33
offset_top = -135.0
offset_right = 145.33
offset_bottom = 135.0
theme_override_fonts/normal_font = ExtResource("3_x0g10")
theme_override_font_sizes/normal_font_size = 13
text = "8444.2 For the purposes of improved clarity in regards to the Cimmerian Charter, per Resolution #739 of the Second Lumos Agreement, significant disruptions to the Global State of Balance are characterized as follows:

- 8444.2a Any action or chain of actions that shifts or carries the possibility of shifting the Global Vector of Economic Progress by a gradient higher than 0.05
"

[node name="5" parent="ZoomedContent" index="4" instance=ExtResource("4_inffp")]

[node name="TextureRect" parent="ZoomedContent/5" index="0"]
texture = ExtResource("2_4qose")

[node name="RichTextLabel" parent="ZoomedContent/5" index="1"]
offset_left = -150.0
