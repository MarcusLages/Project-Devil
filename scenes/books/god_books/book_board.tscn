text = "CLIENT REGIMENT
PAGES 5373-5375


8442. Payment Methods

8442.1 Blood is the standard method of payment for Bargain Sacrifices™. Blood offers must obligatorily inform their volume amount in their proposal using Standard Yogmath Measuring Units (liters).

8442.2 In conformity with the Interfactional "

[node name="RichTextLabel2" parent="ZoomedContent/1" index="2"]
offset_left = 8.33
offset_top = -135.0
offset_right = 145.33
offset_bottom = 135.0
theme_override_fonts/normal_font = ExtResource("3_x0g10")
theme_override_font_sizes/normal_font_size = 13
text = "Treaty of Ballindor (page 344), Blood offers matching the following criteria are not to be accepted by the Board:

- 8442.2a Volumes exceeding clients’ own physical reservoirs, divided by client’s offer payment timeline;"

[node name="2" parent="ZoomedContent" index="1" instance=ExtResource("4_inffp")]

[node name="TextureRect" parent="ZoomedContent/2" index="0"]
texture = ExtResource("2_4qose")

[node name="RichTextLabel" parent="ZoomedContent/2" index="1"]
offset_left = -150.0
offset_top = -135.0
offset_right = -13.0
offset_bottom = 135.0
theme_override_fonts/normal_font = ExtResource("3_x0g10")
theme_override_font_sizes/normal_font_size = 13
text = "- 8442.2b Sourced from Article II Acts of Violence, including (but not limited to) homicide, war, intercourse,  underwater mining, reading, affronts to Class I Lifeforms, mountain climbing and vehicular manslaughter;

- 8442.2c Within composts containing, mixed into or in contact with flesh, rubber, wood (baobab) or ███████;"

[node name="RichTextLabel2" parent="ZoomedContent/2" index="2"]
offset_left = 8.33
offset_top = -135.0
offset_right = 145.33
offset_bottom = 135.0
theme_override_fonts/normal_font = ExtResource("3_x0g10")
theme_override_font_sizes/normal_font_size = 13
text = "- 8442.2d Tainted by undeceased practitioners of deity communion;

- 8442.2e From the sky.

8442.3 Monetary Sigils of Trade, commonly known as credits, may also be offered as payment in Bargain Sacrifices™, either directly or indirectly. In accordance to the Laws of the Nebadenesh, offers are to be made in one of the following forms of transfer:"

[node name="3" parent="ZoomedContent" index="2" instance=ExtResource("4_inffp")]

[node name="TextureRect" parent="ZoomedContent/3" index="0"]
texture = ExtResource("2_4qose")

[node name="RichTextLabel" parent="ZoomedContent/3" index="1"]
offset_left = -150.0
offset_top = -135.0
offset_right = -13.0
offset_bottom = 135.0
theme_override_fonts/normal_font = ExtResource("3_x0g10")
theme_override_font_sizes/normal_font_size = 13
text = "- 8442.3a Direct transfer of capital, either instantly or over the course of several Standard Yogmath Chronologies (years);

- 8442.3b Holy tithes (either the voluntary living, or the involuntary dead), in representation of one tenth of its owner’s ██████;"

[node name="RichTextLabel2" parent="ZoomedContent/3" index="2"]
offset_left = 8.33
offset_top = -135.0
offset_right = 145.33
offset_bottom = 135.0
theme_override_fonts/normal_font = ExtResource("3_x0g10")
theme_override_font_sizes/normal_font_size = 13
text = "- 8442.3c Hands of labor, in representation of future generation of value;

- 8442.3d Glimpses into the future, in representation of stock exchange value fluctuation trend estimations;

- 8442.3e Souls."

[node name="4" parent="ZoomedContent" index="3" instance=ExtResource("4_inffp")]

[node name="TextureRect" parent="ZoomedContent/4" index="0"]
